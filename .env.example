# TLS (optional -- server runs HTTP if these files are absent)
export TLS_CERT_FILE=./certs/server.crt
export TLS_KEY_FILE=./certs/server.key

# PostgreSQL
export DB_HOST=localhost
export DB_PORT=5432
export DB_USER=postgres
export DB_PASSWORD=postgres
export DB_NAME=postgres
export DB_SSL_MODE=disable

# JWT (base64-encoded secret)
export JWT_SECRET=changeme-base64-encoded-secret

# Google OAuth
export GOOGLE_AUTH_SECRET=your-google-auth-secret
export GOOGLE_AUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
